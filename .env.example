# Copy to `.env` before `docker compose up`:  cp .env.example .env
# Windows PowerShell: Copy-Item .env.example .env
# `.env` is gitignored — do not commit it.

# --- Phoenix: PostgreSQL (phoenix-db service) ---
PHOENIX_POSTGRES_USER=postgres
PHOENIX_POSTGRES_PASSWORD=phx_local_dev_change_me
PHOENIX_POSTGRES_DB=phoenix_api

# Must match PHOENIX_POSTGRES_* (avoid URL-reserved characters in the password, e.g. @ : / #)
PHOENIX_DATABASE_URL=ecto://postgres:phx_local_dev_change_me@phoenix-db/phoenix_api

# Phoenix session/cookie signing key (generate a new one for non-local: mix phx.gen.secret)
PHOENIX_SECRET_KEY_BASE=5d819d822d5f140d0546585c771a8bbcc447ea5fd66933dd9275749c191ebd34c48f88e902a16f3f2d8348aee8d05b13601829a1466682e46136a9c75098e1ce

# --- Symfony: PostgreSQL (symfony-db service) ---
SYMFONY_POSTGRES_USER=postgres
SYMFONY_POSTGRES_PASSWORD=sf_local_dev_change_me
SYMFONY_POSTGRES_DB=symfony_app

SYMFONY_DATABASE_URL=postgres://postgres:sf_local_dev_change_me@symfony-db:5432/symfony_app

# Symfony APP_SECRET (for production use e.g. openssl rand -hex 32)
SYMFONY_APP_SECRET=80e69924c33312bbf76962b913f2496dcd380c9031c9be03fe59372ef6173242
# Symfony auth token HMAC secret (use a different value than SYMFONY_APP_SECRET)
SYMFONY_AUTH_TOKEN_HMAC_SECRET=2d7e384d22ddde76da4d8f6fe8cfef99313c3b4e7e0db1f80584ffb4ac31ab0c
